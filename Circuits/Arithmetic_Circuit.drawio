        <mxCell id="jDhxdSG9Dgp-gSSDS5ut-2" parent="1" style="text;html=1;align=center;fontSize=10;" value="Each bit has one 4×1 MUX selecting Y input, and one Full Adder. Carry ripples left to right. Pattern extends to 16 bits." vertex="1">
          <mxGeometry height="20" width="535" x="587.5" y="816" as="geometry" />
        </mxCell>
        <mxCell id="jDhxdSG9Dgp-gSSDS5ut-72" parent="1" style="text;html=1;strokeColor=#6c8ebf;fillColor=#e8f4fd;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;spacingLeft=8;spacingTop=6;" value="&lt;b&gt;4×1 MUX Y-input selection (S1 S0):&lt;/b&gt;&lt;br&gt;S1 S0 = 00 → Y = 0 (transfer A: output = A+0+0)&lt;br&gt;S1 S0 = 01 → Y = B (ADD: output = A+B)&lt;br&gt;S1 S0 = 10 → Y = B&#39; (SUBTRACT: output = A+B&#39;+1 with Cin=1)&lt;br&gt;S1 S0 = 11 → Y = 1 (INCREMENT: output = A+1)" vertex="1">
          <mxGeometry height="90" width="330" x="690" y="1370" as="geometry" />
        </mxCell>
